#!/bin/bash
export SHELL=$(command -v bash)

CACHE_DIR="/dev/shm/clipsync"
mkdir -p "$CACHE_DIR"

X_DATA_FILE="$CACHE_DIR/x_data.tmp"
W_CHECK_FILE="$CACHE_DIR/w_check.tmp"
DIR_LOCK="$CACHE_DIR/direction.lock"
TIME_LOCK="$CACHE_DIR/time.lock"
SYNC_HASH_FILE="$CACHE_DIR/last_sync.hash"
EMPTY_HASH=$(printf "" | xxh128sum | awk '{print $1}')

log() { echo "[$(date '+%H:%M:%S')] [$1] $2"; }
get_ms() { date +%s%3N; }

calc_hash() {
    local file="$1"
    local mode="$2"
    if [ ! -s "$file" ]; then echo "$EMPTY_HASH"; return; fi
    
    if [ "$mode" == "uri-list" ]; then
        grep -vE '^(copy|cut)$' "$file" | sed 's|^file://||' | tr -d '\n\r' | xxh128sum | awk '{print $1}'
    elif [ "$mode" == "text" ]; then
        tr -d '\0\n\r \t' < "$file" | xxh128sum | awk '{print $1}'
    else
        xxh128sum "$file" | awk '{print $1}'
    fi
}

if ! command -v clipnotify &>/dev/null; then exit 1; fi

log "INFO" "=== [X2W] X11 -> Wayland 守护进程启动 ==="

x2w() {
    while clipnotify; do
        sleep 0.1 

        # ==========================================
        # 拦截回声: 方向冷却锁
        # ==========================================
        NOW=$(get_ms)
        LAST_DIR=$(cat "$DIR_LOCK" 2>/dev/null)
        LAST_TIME=$(cat "$TIME_LOCK" 2>/dev/null || echo 0)

        if [ "$LAST_DIR" == "W2X" ] && [ $((NOW - LAST_TIME)) -lt 1000 ]; then
            log "IGNORE" "处于 W2X 冷却期内，丢弃回声事件。"
            continue
        fi

        TYPE=$(xclip -selection clipboard -t TARGETS -o 2>/dev/null)
        SYNC_MIME=""; PROCESS_MODE=""; SOURCE_MIME=""

        if [[ "$TYPE" =~ "application/x-qt-image" ]] || [[ "$TYPE" =~ "x-special/gnome-copied-files" ]] || [[ "$TYPE" =~ "text/uri-list" ]]; then
            if [[ "$TYPE" =~ "x-special/gnome-copied-files" ]]; then
                SOURCE_MIME="x-special/gnome-copied-files"
            else
                SOURCE_MIME="text/uri-list"
            fi
            SYNC_MIME="text/uri-list"; PROCESS_MODE="uri-list"
        elif [[ "$TYPE" =~ "image/png" ]]; then
            SYNC_MIME="image/png"; SOURCE_MIME="image/png"; PROCESS_MODE="raw"
        elif [[ "$TYPE" =~ "image/jpeg" ]]; then
            SYNC_MIME="image/jpeg"; SOURCE_MIME="image/jpeg"; PROCESS_MODE="raw"
        elif [[ "$TYPE" =~ "UTF8_STRING" ]]; then
            SYNC_MIME="text/plain"; SOURCE_MIME="UTF8_STRING"; PROCESS_MODE="text"
        else
            continue
        fi

        timeout 3s xclip -sel clip -o -t "$SOURCE_MIME" > "$X_DATA_FILE" 2>/dev/null
        CURRENT_HASH=$(calc_hash "$X_DATA_FILE" "$PROCESS_MODE")

        if [[ "$CURRENT_HASH" == "$EMPTY_HASH" ]]; then continue; fi

        LAST_SYNC=$(cat "$SYNC_HASH_FILE" 2>/dev/null)
        if [[ "$CURRENT_HASH" == "$LAST_SYNC" ]]; then continue; fi

        timeout 1s wl-paste -t "$SYNC_MIME" > "$W_CHECK_FILE" 2>/dev/null
        W_HASH=$(calc_hash "$W_CHECK_FILE" "$PROCESS_MODE")

        if [[ "$CURRENT_HASH" == "$W_HASH" ]]; then
            log "SKIP" "Wayland 目标端已有相同内容，跳过。"
            echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"
            continue
        fi

        log "ACTION" "准备写入 Wayland... (Hash: ${CURRENT_HASH:0:8})"

        # ==========================================
        # 加锁并写入
        # ==========================================
        echo "X2W" > "$DIR_LOCK"
        get_ms > "$TIME_LOCK"
	pkill -U "$(id -u)" -x xclip 2>/dev/null
        case "$PROCESS_MODE" in
            "uri-list")
                grep -vE '^(copy|cut)$' "$X_DATA_FILE" | sed 's|^/|file:///|' > "$CACHE_DIR/x_format.tmp"
                wl-copy --type text/uri-list < "$CACHE_DIR/x_format.tmp"
                ;;
            "text" | "raw")
                wl-copy -t "$SYNC_MIME" < "$X_DATA_FILE"
                ;;
        esac

        if [ $? -eq 0 ]; then 
            log "SUCCESS" "写入 Wayland 完成"
            echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"
        fi
    done
}

x2w

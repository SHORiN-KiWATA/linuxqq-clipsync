#!/bin/bash
export SHELL=$(command -v bash)

CACHE_DIR="/dev/shm/clipsync"
mkdir -p "$CACHE_DIR"

W_DATA_FILE="$CACHE_DIR/w_data.tmp"
X_CHECK_FILE="$CACHE_DIR/x_check.tmp"
DIR_LOCK="$CACHE_DIR/direction.lock"
TIME_LOCK="$CACHE_DIR/time.lock"
SYNC_HASH_FILE="$CACHE_DIR/last_sync.hash"
EMPTY_HASH=$(printf "" | xxh128sum | awk '{print $1}')

log() { echo "[$(date '+%H:%M:%S')] [$1] $2"; }
get_ms() { date +%s%3N; }

# ==========================================
# 极限去噪哈希计算
# ==========================================
calc_hash() {
    local file="$1"
    local mode="$2"
    if [ ! -s "$file" ]; then echo "$EMPTY_HASH"; return; fi
    
    if [ "$mode" == "uri-list" ]; then
        grep -vE '^(copy|cut)$' "$file" | sed 's|^file://||' | tr -d '\n\r' | xxh128sum | awk '{print $1}'
    elif [ "$mode" == "text" ]; then
        # 纯文本：强制剔除空格、制表符、换行符、空字符的干扰
        tr -d '\0\n\r \t' < "$file" | xxh128sum | awk '{print $1}'
    else
        xxh128sum "$file" | awk '{print $1}'
    fi
}

sleep 0.1

# ==========================================
# 1. 拦截回声: 方向冷却锁 (1000毫秒)
# ==========================================
NOW=$(get_ms)
LAST_DIR=$(cat "$DIR_LOCK" 2>/dev/null)
LAST_TIME=$(cat "$TIME_LOCK" 2>/dev/null || echo 0)

if [ "$LAST_DIR" == "X2W" ] && [ $((NOW - LAST_TIME)) -lt 1000 ]; then
    log "IGNORE" "处于 X2W 冷却期内，丢弃回声事件。"
    exit 0
fi

log "INFO" "=== [W2X] 检测 Wayland 剪贴板 ==="

TYPE=$(wl-paste --list-types 2>/dev/null)
SYNC_MIME=""; PROCESS_MODE=""

if [[ "$TYPE" =~ "application/x-qt-image" ]] || [[ "$TYPE" =~ "text/uri-list" ]]; then
    SYNC_MIME="text/uri-list"; PROCESS_MODE="uri-list"
elif [[ "$TYPE" =~ "text/html" ]]; then
    SYNC_MIME="text/html"; PROCESS_MODE="raw"
elif [[ "$TYPE" =~ "image/png" ]]; then
    SYNC_MIME="image/png"; PROCESS_MODE="raw"
elif [[ "$TYPE" =~ "image/jpeg" ]]; then
    SYNC_MIME="image/jpeg"; PROCESS_MODE="raw"
elif [[ "$TYPE" =~ "text/plain" ]]; then
    SYNC_MIME="text/plain"; PROCESS_MODE="text"
else
    exit 0
fi

timeout 3s wl-paste -t "$SYNC_MIME" > "$W_DATA_FILE" 2>/dev/null
CURRENT_HASH=$(calc_hash "$W_DATA_FILE" "$PROCESS_MODE")

if [[ "$CURRENT_HASH" == "$EMPTY_HASH" ]]; then exit 0; fi

LAST_SYNC=$(cat "$SYNC_HASH_FILE" 2>/dev/null)
if [[ "$CURRENT_HASH" == "$LAST_SYNC" ]]; then exit 0; fi

timeout 1s xclip -sel clip -o -t "$SYNC_MIME" > "$X_CHECK_FILE" 2>/dev/null
X_HASH=$(calc_hash "$X_CHECK_FILE" "$PROCESS_MODE")

if [[ "$CURRENT_HASH" == "$X_HASH" ]]; then
    log "SKIP" "X11 目标端已有相同内容，跳过。"
    echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"
    exit 0
fi

log "ACTION" "准备写入 X11... (Hash: ${CURRENT_HASH:0:8})"

# ==========================================
# 加锁并写入
# ==========================================
echo "W2X" > "$DIR_LOCK"
get_ms > "$TIME_LOCK"

case "$PROCESS_MODE" in
    "uri-list")
        grep -vE '^(copy|cut)$' "$W_DATA_FILE" | sed 's|^/|file:///|' > "$CACHE_DIR/w_format.tmp"
        xclip -sel clip -i -t text/uri-list < "$CACHE_DIR/w_format.tmp"
        ;;
    "text")
        xclip -sel clip -i -t UTF8_STRING < "$W_DATA_FILE"
        ;;
    "raw")
        xclip -sel clip -i -t "$SYNC_MIME" < "$W_DATA_FILE"
        ;;
esac

if [ $? -eq 0 ]; then 
    log "SUCCESS" "写入 X11 完成"
    echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"
fi

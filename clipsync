#!/bin/bash
export SHELL=$(command -v bash)

# ==========================================
# 0. 全局变量与缓存目录初始化
# ==========================================
CACHE_DIR="/dev/shm/clipsync"
mkdir -p "$CACHE_DIR"

SYNC_STATE_LOCK="$CACHE_DIR/sync_state.lock"
SYNC_HASH_FILE="$CACHE_DIR/last_sync.hash"

X_DATA_FILE="$CACHE_DIR/x_data.tmp"
X_CHECK_FILE="$CACHE_DIR/x_check.tmp"
W_DATA_FILE="$CACHE_DIR/w_data.tmp"
W_CHECK_FILE="$CACHE_DIR/w_check.tmp"

EMPTY_HASH_RAW=$(printf "" | xxh128sum)
EMPTY_HASH="${EMPTY_HASH_RAW%% *}"

log() { printf "[%(%H:%M:%S)T] [%s] %s\n" -1 "$1" "$2"; }
get_ms() {
    if [[ -n "$EPOCHREALTIME" ]]; then
        local t="${EPOCHREALTIME/./}"
        echo "${t:0:13}"
    else
        date +%s%3N
    fi
}

# 恢复文件落地机制，防剪贴板死锁
calc_hash() {
    local file="$1"
    local mode="$2"
    local raw_hash
    if [[ ! -s "$file" ]]; then echo "$EMPTY_HASH"; return; fi
    
    if [[ "$mode" == "uri-list" ]]; then
        raw_hash=$(sed '/^\(copy\|cut\)$/d; s|^file://||' "$file" | tr -d '\n\r' | xxh128sum)
    elif [[ "$mode" == "text" ]]; then
        raw_hash=$(tr -d '\0\n\r \t' < "$file" | xxh128sum)
    else
        raw_hash=$(xxh128sum "$file")
    fi
    echo "${raw_hash%% *}"
}

# ==========================================
# 1. 环境嗅探
# ==========================================
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export XAUTHORITY="$HOME/.Xauthority"
export WAYLAND_DISPLAY=""
export DISPLAY=""

for sock in "$XDG_RUNTIME_DIR"/wayland-[0-9]*; do
    [[ -S "$sock" ]] || continue
    TEST_W=$(basename "$sock")
    ERR=$(WAYLAND_DISPLAY="$TEST_W" timeout 1s wl-paste --list-types 2>&1)
    if [[ ! "$ERR" =~ "Failed to connect" ]] && [[ ! "$ERR" =~ "No such file" ]]; then
        export WAYLAND_DISPLAY="$TEST_W"
        break
    fi
done

for sock in /tmp/.X11-unix/X[0-9]*; do
    [[ -S "$sock" ]] || continue
    TEST_D=":${sock##*X}"
    ERR=$(DISPLAY="$TEST_D" timeout 1s xclip -selection clipboard -t TARGETS -o 2>&1)
    if [[ ! "$ERR" =~ "open display" ]]; then
        export DISPLAY="$TEST_D"
        break
    fi
done

log "INIT" "探测结果: DISPLAY=$DISPLAY, WAYLAND_DISPLAY=$WAYLAND_DISPLAY"

if [[ -z "$WAYLAND_DISPLAY" || -z "$DISPLAY" ]]; then
    log "FATAL" "找不到存活的图形界面，触发重启..."
    exit 1
fi

if ! command -v clipnotify &>/dev/null; then exit 1; fi

# ==========================================
# 2. X11 -> Wayland 守护 (作为后台子进程运行)
# ==========================================
x2w_daemon() {
    log "INFO" "=== [X2W] 线程启动 ==="
    while clipnotify; do
        sleep 0.1 
        NOW=$(get_ms)
        read -r LAST_DIR LAST_TIME < "$SYNC_STATE_LOCK" 2>/dev/null
        LAST_TIME=${LAST_TIME:-0}

        if [[ "$LAST_DIR" == "W2X" ]] && (( NOW - LAST_TIME < 1000 )); then continue; fi

        TYPE=$(xclip -selection clipboard -t TARGETS -o 2>/dev/null)
        SYNC_MIME=""; PROCESS_MODE=""; SOURCE_MIME=""

        case "$TYPE" in
            *x-special/gnome-copied-files*)
                SOURCE_MIME="x-special/gnome-copied-files"; SYNC_MIME="text/uri-list"; PROCESS_MODE="uri-list" ;;
            *application/x-qt-image* | *text/uri-list*)
                SOURCE_MIME="text/uri-list"; SYNC_MIME="text/uri-list"; PROCESS_MODE="uri-list" ;;
            *image/png*)
                SYNC_MIME="image/png"; SOURCE_MIME="image/png"; PROCESS_MODE="raw" ;;
            *image/jpeg*)
                SYNC_MIME="image/jpeg"; SOURCE_MIME="image/jpeg"; PROCESS_MODE="raw" ;;
            *UTF8_STRING*)
                SYNC_MIME="text/plain"; SOURCE_MIME="UTF8_STRING"; PROCESS_MODE="text" ;;
            *) continue ;;
        esac

        # 【核心修复】：先光速落地到文件，释放源软件剪贴板锁，再算哈希
        timeout 3s xclip -sel clip -o -t "$SOURCE_MIME" > "$X_DATA_FILE" 2>/dev/null
        CURRENT_HASH=$(calc_hash "$X_DATA_FILE" "$PROCESS_MODE")
        if [[ "$CURRENT_HASH" == "$EMPTY_HASH" ]]; then continue; fi

        read -r LAST_SYNC < "$SYNC_HASH_FILE" 2>/dev/null
        if [[ "$CURRENT_HASH" == "$LAST_SYNC" ]]; then continue; fi

        # 同样，对端检测也必须落地文件以防死锁
        timeout 0.5s wl-paste -t "$SYNC_MIME" > "$W_CHECK_FILE" 2>/dev/null
        W_HASH=$(calc_hash "$W_CHECK_FILE" "$PROCESS_MODE")

        if [[ "$CURRENT_HASH" == "$W_HASH" ]]; then
            echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"
            continue
        fi

        log "X2W" "写入 Wayland... (Hash: ${CURRENT_HASH:0:8})"
        echo "X2W $(get_ms)" > "$SYNC_STATE_LOCK"
        
        case "$PROCESS_MODE" in
            "uri-list")
                sed '/^\(copy\|cut\)$/d; s|^/|file:///|' "$X_DATA_FILE" > "$CACHE_DIR/x_format.tmp"
                wl-copy --type text/uri-list < "$CACHE_DIR/x_format.tmp" ;;
            "text" | "raw")
                wl-copy -t "$SYNC_MIME" < "$X_DATA_FILE" ;;
        esac
        [[ $? -eq 0 ]] && echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"
    done
}

# ==========================================
# 3. 主进程及清理逻辑
# ==========================================
cleanup() {
    log "SYS" "清理进程并退出..."
    pkill -P $$ 2>/dev/null
    exit
}
trap cleanup SIGINT SIGTERM EXIT

# 启动 X2W 作为独立的后台进程
x2w_daemon &
X2W_PID=$!

log "INFO" "=== [W2X] 线程启动 ==="
log "SYS" "双向剪贴板同步服务已准备就绪！"

# ==========================================
# 4. Wayland -> X11 守护 (在主进程中直接运行，不产生多余 bash)
# 【核心修复】：使用进程替换 < <(...)，防止 while 变成独立的死循环子进程
# ==========================================
while read -r _; do
    sleep 0.1

    # 如果 x2w 崩溃了，主进程也随之退出，触发 systemd 重启
    if ! kill -0 "$X2W_PID" 2>/dev/null; then
        log "ERROR" "X2W 线程意外死亡，触发重启..."
        exit 1
    fi

    NOW=$(get_ms)
    read -r LAST_DIR LAST_TIME < "$SYNC_STATE_LOCK" 2>/dev/null
    LAST_TIME=${LAST_TIME:-0}

    if [[ "$LAST_DIR" == "X2W" ]] && (( NOW - LAST_TIME < 1000 )); then continue; fi

    TYPE=$(wl-paste --list-types 2>/dev/null)
    SYNC_MIME=""; PROCESS_MODE=""

    case "$TYPE" in
        *application/x-qt-image* | *text/uri-list*)
            SYNC_MIME="text/uri-list"; PROCESS_MODE="uri-list" ;;
        *text/html*)
            SYNC_MIME="text/html"; PROCESS_MODE="raw" ;;
        *image/png*)
            SYNC_MIME="image/png"; PROCESS_MODE="raw" ;;
        *image/jpeg*)
            SYNC_MIME="image/jpeg"; PROCESS_MODE="raw" ;;
        *text/plain*)
            SYNC_MIME="text/plain"; PROCESS_MODE="text" ;;
        *) continue ;;
    esac

    # 【核心修复】：落地文件，防止大图复制卡死桌面
    timeout 3s wl-paste -t "$SYNC_MIME" > "$W_DATA_FILE" 2>/dev/null
    CURRENT_HASH=$(calc_hash "$W_DATA_FILE" "$PROCESS_MODE")
    if [[ "$CURRENT_HASH" == "$EMPTY_HASH" ]]; then continue; fi

    read -r LAST_SYNC < "$SYNC_HASH_FILE" 2>/dev/null
    if [[ "$CURRENT_HASH" == "$LAST_SYNC" ]]; then continue; fi

    timeout 0.5s xclip -sel clip -o -t "$SYNC_MIME" > "$X_CHECK_FILE" 2>/dev/null
    X_HASH=$(calc_hash "$X_CHECK_FILE" "$PROCESS_MODE")

    if [[ "$CURRENT_HASH" == "$X_HASH" ]]; then
        echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"
        continue
    fi

    log "W2X" "写入 X11... (Hash: ${CURRENT_HASH:0:8})"
    echo "W2X $(get_ms)" > "$SYNC_STATE_LOCK"

    case "$PROCESS_MODE" in
        "uri-list")
            sed '/^\(copy\|cut\)$/d; s|^/|file:///|' "$W_DATA_FILE" > "$CACHE_DIR/w_format.tmp"
            xclip -sel clip -i -t text/uri-list < "$CACHE_DIR/w_format.tmp" ;;
        "text")
            xclip -sel clip -i -t UTF8_STRING < "$W_DATA_FILE" ;;
        "raw")
            xclip -sel clip -i -t "$SYNC_MIME" < "$W_DATA_FILE" ;;
    esac
    [[ $? -eq 0 ]] && echo "$CURRENT_HASH" > "$SYNC_HASH_FILE"

done < <(wl-paste --watch echo 2>/dev/null)

# 如果上面的 wl-paste --watch 意外死掉退出了循环，触发重启
log "ERROR" "W2X 监听意外终止，触发重启..."
exit 1
